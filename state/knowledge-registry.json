        "BRANCH_STRATEGY"
      ],
      "depends_on": ["eng-platform", "eng-production"],
      "priority": "domain",
      "audience": ["builder", "orchestrator"],
      "estimated_tokens": 400
    },
    "eng-error-handling": {
      "path": ".opencode/skills/eng-error-handling/SKILL.md",
      "provides": [
        "ERROR_HANDLING"
      ],
      "depends_on": ["eng-platform"],
      "priority": "domain",
      "audience": ["builder", "reviewer"],
      "estimated_tokens": 300
    },
    "eng-refactoring": {
      "path": ".opencode/skills/eng-refactoring/SKILL.md",
      "provides": [
        "REFACTORING_PATTERNS"
      ],
      "depends_on": ["eng-platform", "eng-testing"],
      "priority": "domain",
      "audience": ["builder", "reviewer", "orchestrator"],
      "estimated_tokens": 350
    },
    "eng-documentation": {
      "path": ".opencode/skills/eng-documentation/SKILL.md",
      "provides": [
        "DOCUMENTATION_STANDARDS",
        "DECISION_LOGGING"
      ],
      "depends_on": ["eng-platform"],
      "priority": "domain",
      "audience": ["docs-writer", "builder"],
      "estimated_tokens": 300
    },
    "eng-code-review": {
      "path": ".opencode/skills/eng-code-review/SKILL.md",
      "provides": [
