      ],
      "depends_on": ["eng-platform"],
      "priority": "domain",
      "audience": ["orchestrator"],
      "estimated_tokens": 300
    }
  },

  "agentBaselines": {
    "orchestrator": {
      "alwaysInclude": ["PROJECT_STRUCTURE", "ARCHITECTURE_PATTERNS", "AI_CONTEXT_ENGINEERING"],
      "contextBudget": 2500
    },
    "builder": {
      "alwaysInclude": ["PROJECT_STRUCTURE", "TESTING_UNIT", "ERROR_HANDLING"],
      "contextBudget": 3000
    },
    "reviewer": {
      "alwaysInclude": ["CODE_REVIEW_CHECKLIST", "PROJECT_STRUCTURE"],
      "contextBudget": 2000
    },
    "analyst": {
      "alwaysInclude": [],
      "contextBudget": 1500
    },
    "docs-writer": {
      "alwaysInclude": ["DOCUMENTATION_STANDARDS", "PROJECT_STRUCTURE"],
      "contextBudget": 2000
    },
    "security-auditor": {
      "alwaysInclude": ["SECURITY_AUDIT", "SECRET_MANAGEMENT", "PROJECT_STRUCTURE"],
      "contextBudget": 2000
    }
  },

  "supersedes": {
    "eng-api-design:api-validation": ["eng-platform:api-validation"],
    "eng-backend:error-handling": ["eng-error-handling:general"],
    "eng-backend:service-pattern": ["eng-platform:service-pattern"],
    "eng-security:auth-implementation": ["eng-platform:auth-patterns"],
    "eng-security:input-validation": ["eng-platform:input-validation"],
    "eng-frontend:component-pattern": ["eng-platform:component-pattern"],
    "eng-database:schema-convention": ["eng-platform:schema-convention"],
    "eng-deployment:ci-cd": ["eng-platform:ci-cd"],
    "eng-production:readiness": ["eng-platform:readiness"]
  },

  "stablePrefixComponents": {
    "frameworkHeader": "OpenCode Engineering Framework v1.0. Context compiled for: {agent_type}.",
    "identityTemplate": "Project: {project_name}. Stack: {stack_summary}. Commands: {build}, {lint}, {test}.",
    "architecturalRules": [
      "routes/ never contains business logic",
      "services/ never imports HTTP types",
      "repositories/ contain all SQL",
      "shared/ is pure TypeScript + Zod",
      "components/ui/ has no business logic",
      "Every endpoint auth-gated unless explicitly public",
      "Write tests before or alongside implementation",
      "Run lint and typecheck after changes",
      "Never commit secrets or .env files"
    ]
  },

  "compilerRules": {
    "tokenBudgets": {
      "builder": 3000,
      "reviewer": 2000,
      "analyst": 1500,
      "docs-writer": 2000,
      "security-auditor": 2000,
      "orchestrator": 2500
    },
    "budgetThresholds": {
      "lightCompression": 0.7,
      "mediumCompression": 0.85,
      "aggressiveCompression": 0.95
    },
    "compression": {
      "elideExamples": true,
      "collapseHeaders": true,
      "minAtomTokens": 50
    },
    "deduplication": {
      "similarityThreshold": 0.85,
      "strategy": "hash-with-supersedes"
    },
    "scoring": {
      "weights": {
        "capabilityMatch": 0.5,
        "specificity": 0.2,
        "recency": 0.1,
        "frequency": 0.2
      }
    }
  }
}
