{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "orchestrator",

  // Model is unset — uses whatever provider/model you configured via /connect or environment.
  // To set specific models for tiered routing (premium for orchestrator/builder, cheap for analyst/reviewer):
  //   "model": "anthropic/claude-sonnet-4-20250514",
  //   "small_model": "anthropic/claude-haiku-4-20250514",
  // Or by environment variable: "{env:OPENCODE_MODEL}"
  //
  // Provider options (timeouts, caching) — add your provider config here:
  //   "provider": {
  //     "anthropic": { "options": { "timeout": 600000, "chunkTimeout": 30000, "setCacheKey": true } }
  //   },

  // Context loading: the Context Compiler scans atom files at runtime (no static registry needed).
  // Instructions form the stable prefix always available to agents.
  // Platform spec kept for human reference; compiler selects relevant atoms per-task.
  "instructions": [
    "AGENTS.md",
    "docs/engineering-handbook.md",
    "state/phase.json",
    "state/analysis.json",
    "state/cache/repo-structure.json"
  ],

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "share": "manual",

  "snapshot": true,

  "permission": {
    "external_directory": {
      "~/projects/**": "allow"
    },

    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },

    "edit": {
      "*": "ask"
    },

    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "git stash *": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "which *": "allow",
      "echo *": "allow",
      "pwd *": "allow",
      "whoami *": "allow",
      "node -v *": "allow",
      "npm -v *": "allow",
      "bun -v *": "allow",
      "python --version *": "allow",
      "npm run lint *": "allow",
      "npm run typecheck *": "allow",
      "npm test *": "allow",
      "bun run lint *": "allow",
      "bun run typecheck *": "allow",
      "bun test *": "allow",
      "pnpm run lint *": "allow",
      "pnpm run typecheck *": "allow",
      "pnpm test *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "rmdir *": "deny",
      "curl * | sh": "deny",
      "curl * | bash": "deny",
      "wget * -O - * | sh": "deny",
      "sudo *": "deny",
      "chmod 777 *": "deny"
    },

    "webfetch": "allow",
    "websearch": "allow",

    "task": {
      "*": "allow",
      "analyst": "allow",
      "builder": "allow",
      "reviewer": "allow",
      "docs-writer": "allow",
      "security-auditor": "allow"
    },

    "skill": {
      "*": "allow"
    },

    "todowrite": "allow",

    "question": "allow"
  },

  // MCP Architecture — tiered access per the blueprint:
  //   Tier 0 (always-on, low token cost):  context7
  //   Tier 1 (per-agent, specialized):     sequential-thinking, fetch, memory
  //   Tier 2 (on-demand, heavy):           github, git, postgres, sqlite, docker, brave-search
  //   Tier 3 (restricted, avoid):          filesystem (built-in tools cover this)
  //
  // Every MCP server is globally disabled below and opted-in per agent.
  // This prevents token bloat from unused tool descriptions inflating every message.
  "mcp": {
    // ── TIER 0: Always available (low token cost, broad utility) ──────────
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },

    // ── TIER 1: Specialized reasoning / retrieval ─────────────────────────
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-fetch"],
      "enabled": true
    },

    // ── TIER 2: Heavy / infrequent — enable per-agent only ────────────────
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-git"],
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-brave-search"],
      "enabled": true,
      "env": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres"],
      "enabled": true,
      "env": {
        "DATABASE_URL": "{env:DATABASE_URL}"
      }
    },
    "sqlite": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sqlite"],
      "enabled": true,
      "args": ["--db-path", "{env:SQLITE_DB_PATH:-./data/local.db}"]
    },
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-docker"],
      "enabled": true
    },
    "redis": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-redis"],
      "enabled": true,
      "env": {
        "REDIS_URL": "{env:REDIS_URL:-redis://localhost:6379}"
      }
    },
    "sentry": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sentry"],
      "enabled": true,
      "env": {
        "SENTRY_AUTH_TOKEN": "{env:SENTRY_AUTH_TOKEN}",
        "SENTRY_ORG": "{env:SENTRY_ORG}",
        "SENTRY_PROJECT": "{env:SENTRY_PROJECT}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-playwright"],
      "enabled": true
    },
    "puppeteer": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-puppeteer"],
      "enabled": true
    },

    // ── TIER 3: Restricted — use built-in tools instead, enable only when essential ──
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem"],
      "enabled": true,
      "args": ["{env:WORKSPACE_ROOT:-.}"]
    }
  },

  // Global disable — forces per-agent opt-in. No MCP tool descriptions leak to agents that don't need them.
  "tools": {
    "context7_*": false,
    "sequential-thinking_*": false,
    "memory_*": false,
    "fetch_*": false,
    "github_*": false,
    "git_*": false,
    "brave-search_*": false,
    "postgres_*": false,
    "sqlite_*": false,
    "docker_*": false,
    "redis_*": false,
    "sentry_*": false,
    "playwright_*": false,
    "puppeteer_*": false,
    "filesystem_*": false
  },

  "agent": {
    "orchestrator": {
      "mode": "primary",
      "temperature": 0.2,
      "color": "#5865f2",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "npm *": "allow",
          "bun *": "allow",
          "pnpm *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "wc *": "allow",
          "echo *": "allow"
        },
        "task": {
          "*": "allow",
          "analyst": "allow",
          "builder": "allow",
          "reviewer": "allow",
          "docs-writer": "allow",
          "security-auditor": "allow"
        }
      },
      "tools": {
        "context7_*": true,
        "sequential-thinking_*": true,
        "fetch_*": true,
        "memory_*": true,
        "skill": true
      }
    },

    "analyst": {
      "mode": "subagent",
      "temperature": 0.1,
      // "model": "anthropic/claude-haiku-4-20250514",  // uncomment for tiered routing
      "color": "#57f287",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "wc *": "allow",
          "echo *": "allow"
        },
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "context7_*": true,
        "fetch_*": true,
        "skill": false,
        "todowrite": false
      }
    },

    "builder": {
      "mode": "subagent",
      "temperature": 0.2,
      // "model": "anthropic/claude-sonnet-4-20250514",  // uncomment for tiered routing
      "color": "#ed4245",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "npm *": "allow",
          "bun *": "allow",
          "pnpm *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "wc *": "allow",
          "echo *": "allow",
          "rm *": "deny",
          "rm -rf *": "deny",
          "sudo *": "deny",
          "curl * | sh": "deny"
        },
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "context7_*": false,
        "sequential-thinking_*": true,
        "git_*": true,
        "postgres_*": true,
        "skill": true,
        "todowrite": true
      }
    },

    "reviewer": {
      "mode": "subagent",
      "temperature": 0.1,
      // "model": "anthropic/claude-haiku-4-20250514",  // uncomment for tiered routing
      "color": "#fee75c",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git status *": "allow",
          "npm run lint *": "allow",
          "npm run typecheck *": "allow",
          "bun run lint *": "allow",
          "bun run typecheck *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow"
        },
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "context7_*": false,
        "git_*": true,
        "skill": true,
        "todowrite": false
      }
    },

    "docs-writer": {
      "mode": "subagent",
      "temperature": 0.2,
      // "model": "anthropic/claude-haiku-4-20250514",  // uncomment for tiered routing
      "color": "#eb459e",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "ls *": "allow",
          "cat *": "allow"
        },
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "context7_*": true,
        "fetch_*": true,
        "skill": true,
        "todowrite": false
      }
    },

    "security-auditor": {
      "mode": "subagent",
      "temperature": 0.1,
      // "model": "anthropic/claude-haiku-4-20250514",  // uncomment for tiered routing
      "color": "#9b59b6",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "npm audit *": "allow",
          "bun pm audit *": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow"
        },
        "webfetch": "allow",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "context7_*": true,
        "sequential-thinking_*": true,
        "fetch_*": true,
        "github_*": true,
        "brave-search_*": true,
        "skill": true,
        "todowrite": false
      }
    },

    "plan": {
      "mode": "primary",
      "temperature": 0.1,
      // "model": "anthropic/claude-haiku-4-20250514",  // uncomment for tiered routing
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "wc *": "allow"
        },
        "task": {
          "*": "deny",
          "analyst": "allow"
        }
      }
    }
  },

  "server": {
    "port": 4096,
    "hostname": "127.0.0.1"
  },

  "experimental": {}
}
